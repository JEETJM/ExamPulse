<% layout('layouts/boilerplate') %>

<h2 class="fw-bold text-light mb-4">Admin Dashboard</h2>

<div class="row g-4 mb-4">
  <div class="col-md-6 col-lg-3">
    <div class="glass-card p-4 dashboard-stat">
      <h6 class="text-light-emphasis">Students</h6>
      <h2 class="text-light"><%= totalStudents %></h2>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="glass-card p-4 dashboard-stat">
      <h6 class="text-light-emphasis">Teachers</h6>
      <h2 class="text-light"><%= totalTeachers %></h2>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="glass-card p-4 dashboard-stat">
      <h6 class="text-light-emphasis">Pending Teachers</h6>
      <h2 class="text-light"><%= pendingTeachers.length %></h2>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="glass-card p-4 dashboard-stat">
      <h6 class="text-light-emphasis">Total Exams</h6>
      <h2 class="text-light"><%= exams.length %></h2>
    </div>
  </div>
</div>

<div class="glass-card p-4 mb-5">
  <h4 class="text-light mb-3">Pending Teacher Approvals</h4>
  <% if (!pendingTeachers.length) { %>
    <div class="alert alert-success">No pending teacher approvals.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-dark table-hover align-middle">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% pendingTeachers.forEach(teacher => { %>
            <tr>
              <td><%= teacher.name %></td>
              <td><%= teacher.email %></td>
              <td>
                <form action="/admin/teachers/<%= teacher._id %>/approve" method="POST">
                  <button class="btn btn-success btn-sm">Approve</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div class="glass-card p-4">
  <h4 class="text-light mb-3">Exam Approval Panel</h4>
  <div class="table-responsive">
    <table class="table table-dark table-hover align-middle">
      <thead>
        <tr>
          <th>Title</th>
          <th>Teacher</th>
          <th>Approved</th>
          <th>Published</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% exams.forEach(exam => { %>
          <tr>
            <td><%= exam.title %></td>
            <td><%= exam.createdBy?.name || "N/A" %></td>
            <td>
              <% if (exam.isApproved) { %>
                <span class="badge bg-success">Approved</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } %>
            </td>
            <td>
              <% if (exam.isPublished) { %>
                <span class="badge bg-primary">Published</span>
              <% } else { %>
                <span class="badge bg-secondary">Not Published</span>
              <% } %>
            </td>
            <td>
              <% if (!exam.isApproved) { %>
                <form action="/admin/exams/<%= exam._id %>/approve" method="POST">
                  <button class="btn btn-primary btn-sm">Approve Exam</button>
                </form>
              <% } else { %>
                <button class="btn btn-success btn-sm" disabled>Done</button>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>